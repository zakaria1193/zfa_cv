      "medium": "https://konstantinmuenster.medium.com",
      "linkedin": "https://www.linkedin.com/in/fadlizakaria/",
      "mail": "mailto:mail@konstantin.digital"
    }
  },
  "siteConfiguration": {
    "logo": { "text": "Zakaria" },
    "navigation": {
      "header": [
        { "label": "CV", "url": "/#about" },
        { "label": "Blog", "url": "/blog" },
        { "label": "Features", "url": "/#features" },
        { "label": "Github", "url": "/#github" }
      ],
      "ctaButton": {
        "openNewTab": true,
